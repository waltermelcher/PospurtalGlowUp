---
export interface Props { title: string }
const { title } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<div class="legal">
  <div class="container legal-inner">
    <a href={base} class="legal-back">← Zurück zur Startseite</a>
    <h1>{title}</h1>
    <div class="legal-body">
      <slot />
    </div>
  </div>
</div>

<style>
  .legal { padding-block: clamp(7rem, 14vw, 10rem) clamp(4rem, 8vw, 6rem); }
  .legal-inner { max-width: 760px; }
  .legal-back {
    color: var(--brass-soft);
    font-size: 0.9rem;
    font-weight: 500;
    transition: opacity 0.3s;
  }
  .legal-back:hover { opacity: 0.7; }
  .legal h1 {
    font-size: clamp(2.4rem, 6vw, 3.6rem);
    margin: 1.2rem 0 2.5rem;
  }
  .legal-body :global(h2) {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    margin: 2.2rem 0 0.8rem;
    color: var(--brass-soft);
  }
  .legal-body :global(p) { color: var(--text-soft); margin-bottom: 1rem; }
  .legal-body :global(a) { color: var(--brass-soft); text-decoration: underline; text-underline-offset: 3px; }
  .legal-body :global(.muted) { color: var(--text-mute); font-size: 0.9rem; }
</style>
