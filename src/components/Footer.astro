---
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <img src={`${base}images/logo_white.webp`} alt="Pospurtal" width="170" height="46" />
      <p>Das Rheinhessische Posaunenquartett — klangvolle Geschichten zwischen Tradition und Vielfalt.</p>
    </div>

    <nav class="footer-nav" aria-label="Footer-Navigation">
      <span class="footer-nav-title">Navigation</span>
      <a href={`${base}#konzerte`}>Konzerte</a>
      <a href={`${base}#musiker`}>Musiker</a>
      <a href={`${base}#medien`}>Medien</a>
      <a href={`${base}#kontakt`}>Kontakt</a>
    </nav>

    <div class="footer-contact">
      <span class="footer-nav-title">Kontakt</span>
      <a href="mailto:hallo@pospurtal.de">hallo@pospurtal.de</a>
      <div class="footer-social">
        <a href="https://www.instagram.com" target="_blank" rel="noopener" aria-label="Instagram">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
        </a>
        <a href="https://www.facebook.com" target="_blank" rel="noopener" aria-label="Facebook">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M14 9h3V6h-3c-1.7 0-3 1.3-3 3v2H9v3h2v6h3v-6h2.5l.5-3H14V9.5c0-.3.2-.5.5-.5z"/></svg>
        </a>
      </div>
    </div>
  </div>

  <div class="footer-bottom container">
    <span>© {year} Pospurtal. Alle Rechte vorbehalten.</span>
    <div class="footer-legal">
      <a href={`${base}impressum`}>Impressum</a>
      <a href={`${base}datenschutz`}>Datenschutz</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #100D0C;
    border-top: 1px solid var(--line-soft);
    padding-top: clamp(3rem, 6vw, 5rem);
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    padding-bottom: 3rem;
  }
  .footer-brand img { height: 38px; width: auto; margin-bottom: 1.2rem; }
  .footer-brand p { color: var(--text-mute); font-size: 0.95rem; max-width: 38ch; }

  .footer-nav, .footer-contact { display: flex; flex-direction: column; gap: 0.7rem; }
  .footer-nav-title {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--brass-soft);
    margin-bottom: 0.4rem;
  }
  .footer-nav a, .footer-contact a {
    color: var(--text-soft);
    font-size: 0.95rem;
    width: fit-content;
    transition: color 0.3s;
  }
  .footer-nav a:hover, .footer-contact a:hover { color: var(--brass-soft); }

  .footer-social { display: flex; gap: 0.7rem; margin-top: 0.6rem; }
  .footer-social a {
    width: 40px; height: 40px;
    display: grid; place-items: center;
    border: 1px solid var(--line-soft);
    border-radius: 50%;
    color: var(--text-soft);
    transition: all 0.3s var(--ease);
  }
  .footer-social a svg { width: 18px; height: 18px; }
  .footer-social a:hover {
    border-color: var(--brass);
    color: var(--brass-soft);
    transform: translateY(-2px);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    padding-block: 1.6rem;
    border-top: 1px solid var(--line-soft);
    color: var(--text-mute);
    font-size: 0.85rem;
  }
  .footer-legal { display: flex; gap: 1.5rem; }
  .footer-legal a { color: var(--text-mute); transition: color 0.3s; }
  .footer-legal a:hover { color: var(--brass-soft); }

  @media (max-width: 760px) {
    .footer-inner { grid-template-columns: 1fr 1fr; }
    .footer-brand { grid-column: 1 / -1; }
  }
</style>
