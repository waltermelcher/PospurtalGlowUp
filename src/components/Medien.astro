---
const base = import.meta.env.BASE_URL;
const items = [
  { type: 'video', id: '7SDy23zIOMA', thumb: `${base}images/video_bruckner.webp`, span: 'wide', label: 'Bruckner „Scherzo“', alt: 'Pospurtal spielt Anton Bruckner – Scherzo (Video)' },
  { type: 'photo', src: `${base}images/breitbild_1.webp`, span: 'wide', alt: 'Pospurtal im Konzert' },
  { type: 'photo', src: `${base}images/hochkant_1.webp`, span: 'tall', alt: 'Pospurtal Posaunist' },
  { type: 'video', id: 'ZUWr3f4E9ps', thumb: `${base}images/video_konzert1.webp`, span: 'normal', label: 'Konzert 1', alt: 'Pospurtal Konzert 1 (Video)' },
  { type: 'video', id: 'eWSrBnh1ttM', thumb: `${base}images/video_konzert2.webp`, span: 'normal', label: 'Konzert 2', alt: 'Pospurtal Konzert 2 (Video)' },
  { type: 'photo', src: `${base}images/breitbild_4.webp`, span: 'normal', alt: 'Pospurtal bei der Probe' },
  { type: 'photo', src: `${base}images/breitbild_5.webp`, span: 'normal', alt: 'Pospurtal Auftritt' },
  { type: 'photo', src: `${base}images/breitbild_2.webp`, span: 'wide', alt: 'Pospurtal Ensemble' },
];
---

<section class="medien section" id="medien">
  <div class="container">
    <div class="section-head" data-reveal>
      <p class="eyebrow">Medien</p>
      <h2>Pospurtal vor der Kamera</h2>
      <p class="lead">Eindrücke von Auftritten, Proben und Momenten zwischen den Tönen.</p>
    </div>

    <div class="gallery">
      {items.map((it) => it.type === 'video' ? (
        <button class={`gallery-item ${it.span} gallery-video`} data-reveal data-video={it.id} aria-label={`Video abspielen: ${it.label}`}>
          <img src={it.thumb} alt={it.alt} loading="lazy" />
          <span class="gallery-play" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z" /></svg>
          </span>
          <span class="gallery-vlabel">Video · {it.label}</span>
        </button>
      ) : (
        <button class={`gallery-item ${it.span}`} data-reveal data-full={it.src} aria-label="Bild vergrößern">
          <img src={it.src} alt={it.alt} loading="lazy" />
          <span class="gallery-zoom" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3M11 8v6M8 11h6"/></svg>
          </span>
        </button>
      ))}
    </div>
  </div>

  <div class="lightbox" id="lightbox" aria-hidden="true">
    <button class="lightbox-close" id="lightboxClose" aria-label="Schließen">&times;</button>
    <img id="lightboxImg" class="lightbox-img" src="" alt="" />
    <div id="lightboxVideo" class="lightbox-video"></div>
  </div>
</section>

<style>
  .gallery {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 220px;
    gap: clamp(0.7rem, 1.5vw, 1.1rem);
  }
  .gallery-item {
    position: relative;
    border: none;
    padding: 0;
    border-radius: var(--radius);
    overflow: hidden;
    cursor: pointer;
    background: var(--bg-3);
  }
  .gallery-item.wide { grid-column: span 2; grid-row: span 1; }
  .gallery-item.tall { grid-column: span 1; grid-row: span 2; }
  .gallery-item.normal { grid-column: span 1; grid-row: span 1; }

  .gallery-item img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.7s var(--ease), filter 0.5s var(--ease);
    filter: brightness(0.92);
  }
  .gallery-item:hover img { transform: scale(1.06); filter: brightness(1.05); }
  .gallery-item::after {
    content: "";
    position: absolute; inset: 0;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    pointer-events: none;
  }
  .gallery-zoom {
    position: absolute;
    bottom: 12px; right: 12px;
    width: 40px; height: 40px;
    display: grid; place-items: center;
    background: rgba(20,17,16,0.7);
    backdrop-filter: blur(6px);
    border: 1px solid var(--line);
    border-radius: 50%;
    color: var(--brass-soft);
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.4s var(--ease), transform 0.4s var(--ease);
  }
  .gallery-zoom svg { width: 20px; height: 20px; }
  .gallery-item:hover .gallery-zoom { opacity: 1; transform: none; }

  /* --- Video-Kachel --- */
  .gallery-video img { filter: brightness(0.62); }
  .gallery-video:hover img { filter: brightness(0.72); }
  .gallery-play {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 74px; height: 74px;
    display: grid; place-items: center;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--brass-soft), var(--brass-deep));
    color: #1A1408;
    box-shadow: 0 14px 36px -8px rgba(0,0,0,0.7);
    transition: transform 0.4s var(--ease), box-shadow 0.4s var(--ease);
  }
  .gallery-play svg { width: 30px; height: 30px; margin-left: 3px; }
  .gallery-video:hover .gallery-play {
    transform: translate(-50%, -50%) scale(1.08);
    box-shadow: 0 18px 44px -8px var(--brass-glow);
  }
  .gallery-vlabel {
    position: absolute;
    left: 16px; bottom: 14px;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--text);
    background: rgba(20,17,16,0.6);
    backdrop-filter: blur(6px);
    border: 1px solid var(--line-soft);
    padding: 0.35rem 0.8rem;
    border-radius: 999px;
  }

  .lightbox {
    position: fixed; inset: 0;
    z-index: 200;
    background: rgba(10,8,7,0.94);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4vw;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s var(--ease);
  }
  .lightbox.open { opacity: 1; pointer-events: auto; }
  .lightbox-img {
    max-width: 100%;
    max-height: 88vh;
    border-radius: 8px;
    box-shadow: 0 40px 100px -20px rgba(0,0,0,0.9);
    transform: scale(0.96);
    transition: transform 0.4s var(--ease);
  }
  .lightbox.open .lightbox-img { transform: scale(1); }

  .lightbox-video {
    display: none;
    width: min(92vw, 1280px);
    aspect-ratio: 16 / 9;
    max-height: 86vh;
  }
  .lightbox.video-mode .lightbox-img { display: none; }
  .lightbox.video-mode .lightbox-video { display: block; }
  .lightbox-video :global(iframe) {
    width: 100%; height: 100%;
    border: 0;
    border-radius: 10px;
    box-shadow: 0 40px 100px -20px rgba(0,0,0,0.9);
  }

  .lightbox-close {
    position: absolute;
    top: 1.4rem; right: 1.8rem;
    background: none; border: none;
    color: var(--text);
    font-size: 2.6rem;
    line-height: 1;
    transition: color 0.3s, transform 0.3s;
  }
  .lightbox-close:hover { color: var(--brass-soft); transform: rotate(90deg); }

  @media (max-width: 760px) {
    .gallery { grid-template-columns: repeat(2, 1fr); grid-auto-rows: 160px; }
    .gallery-item.wide { grid-column: span 2; }
    .gallery-item.tall { grid-row: span 2; }
    .gallery-play { width: 60px; height: 60px; }
    .gallery-play svg { width: 24px; height: 24px; }
  }
</style>

<script>
  const lb = document.getElementById('lightbox');
  const lbImg = document.getElementById('lightboxImg') as HTMLImageElement | null;
  const lbVideo = document.getElementById('lightboxVideo');
  const close = document.getElementById('lightboxClose');

  const openImg = (src: string) => {
    if (!lb || !lbImg) return;
    lb.classList.remove('video-mode');
    lbImg.src = src;
    lb.classList.add('open');
    lb.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  };

  const openVideo = (id: string) => {
    if (!lb || !lbVideo) return;
    lbVideo.innerHTML =
      `<iframe src="https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0" ` +
      `title="YouTube-Video" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" ` +
      `allowfullscreen></iframe>`;
    lb.classList.add('open', 'video-mode');
    lb.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  };

  const hide = () => {
    if (!lb) return;
    lb.classList.remove('open', 'video-mode');
    lb.setAttribute('aria-hidden', 'true');
    if (lbVideo) lbVideo.innerHTML = '';
    document.body.style.overflow = '';
  };

  document.querySelectorAll<HTMLElement>('.gallery-item').forEach((el) =>
    el.addEventListener('click', () => {
      if (el.dataset.video) openVideo(el.dataset.video);
      else openImg(el.dataset.full || '');
    })
  );
  close?.addEventListener('click', hide);
  lb?.addEventListener('click', (e) => { if (e.target === lb) hide(); });
  window.addEventListener('keydown', (e) => { if (e.key === 'Escape') hide(); });
</script>
