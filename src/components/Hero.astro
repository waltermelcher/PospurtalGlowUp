---
const base = import.meta.env.BASE_URL;
---

<section class="hero" id="top">
  <div class="hero-bg">
    <img src={`${base}images/header.webp`} alt="Pospurtal Posaunenquartett" fetchpriority="high" />
    <div class="hero-overlay"></div>
    <div class="hero-vignette"></div>
  </div>

  <div class="hero-content container">
    <p class="eyebrow hero-eyebrow">Das Rheinhessische Posaunenquartett</p>
    <h1 class="hero-title">
      <span>Pospurtal</span>
    </h1>
    <p class="hero-sub">
      Klangvolle Geschichten, vielseitige Musik —<br />
      Posaunenklang zwischen Tradition und Vielfalt.
    </p>
    <div class="hero-actions">
      <a href="#konzerte" class="btn btn-primary">
        Konzerte ansehen
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>
  </div>

  <a href="#ueber" class="hero-scroll" aria-label="Nach unten scrollen">
    <span></span>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  .hero-bg { position: absolute; inset: 0; z-index: 0; }
  .hero-bg img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center 42%;
    animation: heroZoom 18s var(--ease) forwards;
  }
  @keyframes heroZoom {
    from { transform: scale(1.12); }
    to   { transform: scale(1); }
  }
  .hero-overlay {
    position: absolute; inset: 0;
    background:
      linear-gradient(180deg, rgba(20,17,16,0.42) 0%, rgba(20,17,16,0.22) 40%, rgba(20,17,16,0.86) 100%),
      linear-gradient(90deg, rgba(20,17,16,0.62) 0%, rgba(20,17,16,0.08) 60%);
  }
  .hero-vignette {
    position: absolute; inset: 0;
    box-shadow: inset 0 0 220px 40px rgba(0,0,0,0.6);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    width: 100%;
    padding-top: 5rem;
  }
  .hero-eyebrow {
    font-size: 0.98rem;
    letter-spacing: 0.24em;
    opacity: 0;
    animation: fadeUp 0.9s var(--ease) 0.3s forwards;
  }
  .hero-eyebrow::before { display: none; }
  .hero-title {
    font-size: clamp(3.6rem, 16vw, 11rem);
    font-weight: 600;
    line-height: 0.92;
    margin: 1.2rem 0 0;
    letter-spacing: -0.02em;
  }
  .hero-title span {
    display: inline-block;
    background: linear-gradient(180deg, #FFF9EC 0%, #F4EEE3 45%, var(--brass-soft) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    opacity: 0;
    animation: fadeUp 1s var(--ease) 0.45s forwards;
    text-shadow: 0 2px 40px rgba(0,0,0,0.3);
  }
  .hero-sub {
    font-size: clamp(1.1rem, 2.4vw, 1.5rem);
    color: var(--text-soft);
    max-width: 36ch;
    margin-top: 1.6rem;
    line-height: 1.5;
    opacity: 0;
    animation: fadeUp 1s var(--ease) 0.62s forwards;
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2.6rem;
    opacity: 0;
    animation: fadeUp 1s var(--ease) 0.8s forwards;
  }

  .hero-scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    width: 26px; height: 42px;
    border: 1.5px solid rgba(244,238,227,0.4);
    border-radius: 20px;
    display: flex;
    justify-content: center;
    padding-top: 8px;
    opacity: 0;
    animation: fadeUp 1s var(--ease) 1s forwards;
  }
  .hero-scroll span {
    width: 3px; height: 8px;
    background: var(--brass-soft);
    border-radius: 3px;
    animation: scrollDot 1.8s var(--ease) infinite;
  }
  @keyframes scrollDot {
    0% { transform: translateY(0); opacity: 1; }
    70% { transform: translateY(14px); opacity: 0; }
    100% { opacity: 0; }
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: none; }
  }
  /* --- Mobile: gestapeltes Layout, ganzes Foto (alle 4 Musiker) sichtbar --- */
  @media (max-width: 700px) {
    .hero {
      min-height: auto;
      flex-direction: column;
      align-items: stretch;
      padding-top: 110px;       /* unter der fixierten Navigation */
      padding-bottom: 3.2rem;
    }
    .hero-bg {
      position: relative;
      inset: auto;
      width: 100%;
    }
    .hero-bg img {
      height: auto;
      aspect-ratio: 5120 / 3413; /* exaktes Bildverhältnis → vollständiges Foto, kein Beschnitt */
      object-fit: cover;
      object-position: center;
      animation: none;
    }
    /* nur dezenter Übergang an der Unterkante ins Dunkle */
    .hero-overlay {
      background: linear-gradient(180deg, rgba(20,17,16,0) 72%, var(--bg) 100%);
    }
    .hero-vignette { display: none; }

    .hero-content {
      position: relative;
      padding-top: 2rem;
    }
    .hero-title { font-size: clamp(3.2rem, 19vw, 5rem); }
    .hero-sub { font-size: 1.1rem; }
    .hero-actions { margin-top: 2rem; }
    .hero-scroll { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-bg img, .hero-eyebrow, .hero-title span, .hero-sub, .hero-actions, .hero-scroll {
      animation: none !important; opacity: 1 !important; transform: none !important;
    }
  }
</style>
