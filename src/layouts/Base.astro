---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Pospurtal – Das Rheinhessische Posaunenquartett',
  description = 'Pospurtal steht für klangvolle Geschichten und vielseitige Musik. Erleben Sie Posaunenklang zwischen Tradition und Vielfalt.',
} = Astro.props;

const base = import.meta.env.BASE_URL;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL(`${base}images/header.webp`, Astro.site).toString();

// Nur auf diesen (Produktions-)Domains darf indexiert werden.
// Auf allen anderen Hosts (GitHub-Pages-Vorschau, Preview, localhost) wird
// per Skript automatisch ein noindex gesetzt – ohne manuelles Umschalten.
const productionHosts = ['pospurtal.de', 'www.pospurtal.de'];
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Indexierung nur auf der Produktions-Domain; sonst automatisch noindex -->
    <script is:inline define:vars={{ productionHosts }}>
      (function () {
        var isProd = productionHosts.indexOf(location.hostname) !== -1;
        if (!isProd) {
          var robots = document.createElement('meta');
          robots.name = 'robots';
          robots.content = 'noindex, nofollow';
          document.head.appendChild(robots);
        } else {
          // Auf Produktion die Canonical-URL auf die echte Domain setzen
          var canon = document.querySelector('link[rel="canonical"]');
          if (canon) canon.setAttribute('href', location.origin + location.pathname);
        }
      })();
    </script>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="de_DE" />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" type="image/webp" href={`${base}images/logo_white.webp`} />
    <meta name="theme-color" content="#141110" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />

    <script>
      // Reveal-on-scroll
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('is-visible');
              io.unobserve(e.target);
            }
          }
        },
        { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
      );
      document.querySelectorAll('[data-reveal]').forEach((el) => io.observe(el));
    </script>
  </body>
</html>
